@baseUrl = http://localhost:3000
@accessToken = replace-with-backend-app-access-token
@productId = replace-with-product-id
@productCategoryId = replace-with-product-category-id
@productStatusId = replace-with-product-status-id
@memoLogId = replace-with-memo-log-id
@privateMemoLogId = replace-with-private-memo-log-id
@cursor = replace-with-next-cursor

### Health
GET {{baseUrl}}/api/health

### List products
GET {{baseUrl}}/api/products?page=1&productName=&productCategoryId=&productStatusId=
Authorization: Bearer {{accessToken}}

### List product categories
GET {{baseUrl}}/api/product-categories
Authorization: Bearer {{accessToken}}

### Create product category
POST {{baseUrl}}/api/product-categories
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "categoryName": "SaaS"
}

### Delete product category
DELETE {{baseUrl}}/api/product-categories/{{productCategoryId}}
Authorization: Bearer {{accessToken}}

### List product statuses
GET {{baseUrl}}/api/product-statuses
Authorization: Bearer {{accessToken}}

### Create product status
POST {{baseUrl}}/api/product-statuses
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "statusName": "판매중"
}

### Delete product status
DELETE {{baseUrl}}/api/product-statuses/{{productStatusId}}
Authorization: Bearer {{accessToken}}

### Create product
POST {{baseUrl}}/api/products
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "productName": "Sales CRM Basic",
  "productPrice": 99000,
  "productCategoryId": "{{productCategoryId}}",
  "productStatusId": "{{productStatusId}}",
  "productMemo": "초기 제품 메모"
}

### Get product
GET {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{accessToken}}

### Update product
PATCH {{baseUrl}}/api/products/{{productId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "productName": "Sales CRM Pro",
  "productPrice": 149000,
  "productCategoryId": "{{productCategoryId}}",
  "productStatusId": "{{productStatusId}}"
}

### Create product memo log
POST {{baseUrl}}/api/products/{{productId}}/memo-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memoType": "고객 피드백",
  "memo": "제품 도입 범위와 가격 조건을 확인했다."
}

### List product memo logs
GET {{baseUrl}}/api/products/{{productId}}/memo-logs
Authorization: Bearer {{accessToken}}

### List product memo logs with cursor
GET {{baseUrl}}/api/products/{{productId}}/memo-logs?cursor={{cursor}}
Authorization: Bearer {{accessToken}}

### Update product memo log
PATCH {{baseUrl}}/api/products/{{productId}}/memo-logs/{{memoLogId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memoType": "후속 확인",
  "memo": "수정된 일반 메모"
}

### Create product private memo log
POST {{baseUrl}}/api/products/{{productId}}/private-memo-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memo": "본인만 볼 수 있는 제품 비밀 메모"
}

### List product private memo logs
GET {{baseUrl}}/api/products/{{productId}}/private-memo-logs
Authorization: Bearer {{accessToken}}

### List product private memo logs with cursor
GET {{baseUrl}}/api/products/{{productId}}/private-memo-logs?cursor={{cursor}}
Authorization: Bearer {{accessToken}}

### Update product private memo log
PATCH {{baseUrl}}/api/products/{{productId}}/private-memo-logs/{{privateMemoLogId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memo": "수정된 제품 개인 비밀 메모"
}
